{
  "manifest_version": 3,
  "name": "FrontScript Tooltip Helper",
  "version": "2.0",
  "description": "IntelliSense tooltips, autocomplete, side panel reference, and snippet insertion for FrontScript.",
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "tooltip.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "frontscript-tooltips.json",
        "snippets.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
